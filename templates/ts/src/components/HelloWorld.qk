        display: grid;
        background-color: #2a2a2a;
        grid-template-columns: 1fr 1fr;
        border-top: 1px solid #2a2a2a;
    }

    .footer-panel {
        text-align: start;
        padding: 3em 2em 0;
        background-color: #1a1a1a;
    }

    .panel-title {
        font-size: 1.1rem;
        font-weight: 600;
