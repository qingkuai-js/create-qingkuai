<lang-ts>
    interface Props {
        title: string
    }

    let count = 0

    const increase = () => {
        count++
    }

    const reset = () => {
        count = 0
    }

    const decrease = () => {
        if (count > 0) {
            count--
        }
    }
</lang-ts>

<div class="hero">
    <h1 class="hero-title">{props.title}</h1>
    <p class="hero-subtitle">A modern, reactive framework for building web applications</p>

    <div class="counter-section">
        <p class="count-label">You have clicked <span class="count-value">{count}</span> times</p>
        <div class="counter-buttons">
            <button
                type="button"
                @click={increase}
                class="counter-btn"
            >
                increase
            </button>
            <button
                type="button"
                @click={reset}
                class="counter-btn counter-btn--reset"
            >
                reset
            </button>
            <button
                type="button"
                @click={decrease}
                class="counter-btn"
            >
                decrease
            </button>
        </div>
    </div>
</div>

<div class="features-grid">
    <div class="feature-item">
        <div class="feature-icon">⚡</div>
        <h3>Lightning Fast</h3>
        <p>Ultra-fast reactivity with instant HMR</p>
    </div>
    <div class="feature-item">
        <div class="feature-icon">📝</div>
        <h3>TypeScript First</h3>
        <p>Natural and intuitive type system support</p>
    </div>
    <div class="feature-item">
        <div class="feature-icon">🎨</div>
        <h3>Elegant Styling</h3>
        <p>Seamless integration with modern CSS</p>
    </div>
    <div class="feature-item">
        <div class="feature-icon">📦</div>
        <h3>Lightweight</h3>
        <p>Minimal bundle size and fast builds</p>
    </div>
    <div class="feature-item">
        <div class="feature-icon">🔧</div>
        <h3>Native Feel</h3>
        <p>Close to JavaScript/TypeScript development</p>
    </div>
    <div class="feature-item">
        <div class="feature-icon">🛠️</div>
        <h3>Smart Tools</h3>
        <p>Complete language services and AI support</p>
    </div>
    <div class="feature-item">
        <div class="feature-icon">📚</div>
        <h3>Clear Docs</h3>
        <p>Step-by-step guides for practical workflows</p>
    </div>
    <div class="feature-item">
        <div class="feature-icon">🧩</div>
        <h3>Composable</h3>
        <p>Build complex interfaces from simple components</p>
    </div>
    <div class="feature-item">
        <div class="feature-icon">🔒</div>
        <h3>Reliable</h3>
        <p>Predictable updates and stable rendering behavior</p>
    </div>
    <div class="feature-item">
        <div class="feature-icon">🔍</div>
        <h3>Great DevX</h3>
        <p>Preserves source variable names for seamless debugging</p>
    </div>
</div>

<div class="footer-panels">
    <div class="footer-panel">
        <div class="panel-links-row">
            <a
                target="_blank"
                href="https://qingkuai.dev"
                title="qingkuai Documentation"
                class="icon-link icon-link--docs"
            >
                <img
                    alt="qingkuai logo"
                    class="icon-link-img"
                    src="/src/assets/imgs/qingkuai.svg"
                />
                Qingkuai Docs
            </a>
            <a
                target="_blank"
                title="VS Code Extension"
                class="icon-link icon-link--vscode"
                href="https://marketplace.visualstudio.com/items?itemName=qingkuai-tools.qingkuai-language-features"
            >
                <img
                    alt="vscode logo"
                    class="icon-link-img"
                    src="/src/assets/imgs/vscode.svg"
                />
                VS Code Extension
            </a>
        </div>
        <h3 class="panel-title">Developer Resources</h3>
        <p class="panel-desc">Official docs and IDE tooling to speed up development</p>
    </div>
    <div class="footer-panel">
        <div class="panel-links-row">
            <a
                target="_blank"
                title="GitHub"
                class="icon-link icon-link--github"
                href="https://github.com/qingkuai-js/qingkuai"
            >
                <img
                    alt="github logo"
                    class="icon-link-img"
                    src="/src/assets/imgs/github.svg"
                />
                GitHub
            </a>
            <a
                title="npm"
                target="_blank"
                class="icon-link icon-link--npm"
                href="https://www.npmjs.com/package/qingkuai"
            >
                <img
                    alt="npm logo"
                    class="icon-link-img"
                    src="/src/assets/imgs/npm.svg"
