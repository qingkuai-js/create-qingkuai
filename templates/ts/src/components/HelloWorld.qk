        font-weight: 500;
        color: #2196f3;
        text-decoration: none;
        border: 1px solid #2a3a4a;
        border-radius: 6px;
        padding: 0.4rem 1rem;
        transition: all 0.15s;
    }

    .panel-link:hover {
        background-color: #1a2a3a;
        border-color: #2196f3;
        text-decoration: none;
    }

    .panel-links-row {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .icon-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 0.9rem;
        border-radius: 6px;
        border: 1px solid #333;
        font-size: 0.85rem;
