        </div>
        <h3 class="panel-title">Project Channels</h3>
        <p class="panel-desc">Source code and package publishing channels</p>
    </div>
</div>

<lang-css>
    .hero {
        text-align: center;
        padding: 0 2rem 2rem;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 0.75rem;
        letter-spacing: -0.02em;
    }

    .hero-subtitle {
        font-size: 1.1rem;
        color: #888;
        margin-bottom: 2rem;
    }

    .counter-section {
        display: inline-block;
        margin: 0 auto;
    }

    .count-label {
        font-size: 1rem;
        color: #888;
        margin-bottom: 0.75rem;
    }

    .count-value {
        font-weight: 700;
        color: #fff;
    }

    .counter-buttons {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
    }

    .counter-btn {
        padding: 0.5rem 1.25rem;
